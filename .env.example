# Copy this file to `.env.local` for local development.
# In production, set the same values in Vercel → Project → Settings → Environment Variables.
# NEVER commit `.env.local` — it's gitignored.

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_your_key_here

# Email address that booking submissions are delivered to.
# On Resend's free tier, this must be the email registered with
# your Resend account (until you verify a custom sending domain).
BOOKING_TO_EMAIL=your-email@example.com

# Optional: override the sender. Defaults to "ComfortLine <onboarding@resend.dev>"
# which works without domain verification but lands the email in your
# inbox from Resend's shared sender. To send from your own domain
# (e.g. bookings@comfortline.com) you must verify the domain in Resend first.
# BOOKING_FROM_EMAIL=ComfortLine <bookings@comfortline.com>
